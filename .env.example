# =============================================
# SaaS School Management System - Root Environment
# =============================================
# Copy this file to .env and update values for production

# Application
APP_NAME="SaaS School ERP"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://app.yourdomain.com
APP_KEY=

# Frontend
FRONTEND_URL=https://app.yourdomain.com
API_URL=https://api.yourdomain.com/api
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sms_erp
DB_USERNAME=sms_erp
DB_PASSWORD=your-secure-password
DB_ROOT_PASSWORD=your-root-password

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (Mailgun recommended for production)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@yourdomain.com
MAIL_PASSWORD=your-mailgun-password
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="SaaS School ERP"

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Queue
QUEUE_CONNECTION=redis

# Cache
CACHE_STORE=redis
SESSION_DRIVER=redis
